# Database Configuration (Local Development)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/remyafya
POSTGRES_DB=remyafya
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# JWT Configuration
JWT_SECRET_KEY=remy-care-connect-jwt-secret-key-change-in-production-2024
SECRET_KEY=remy-care-connect-flask-secret-key-change-in-production-2024

# Redis Configuration (Local Development)
REDIS_URL=redis://localhost:6379

# Flask Configuration
FLASK_APP=wsgi:app
FLASK_ENV=development
FLASK_DEBUG=True

# Application Configuration
PYTHONPATH=/app/backend

# CORS — comma-separated list of allowed origins.
# Local dev: leave as-is. In production (Render), override this with your Vercel URL:
#   CORS_ORIGINS=https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:3000
