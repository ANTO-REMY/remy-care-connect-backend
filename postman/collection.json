    "name": "RemyCareConnect API v5 - Optimized & Dynamic",
    "description": "Optimized Postman collection with dynamic ID tracking, complete request bodies, and intelligent variable management. Register → Verify → Login → Complete Profile workflow with automatic ID extraction for mother, CHW, and nurse profiles. Updated February 2026.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": {
      "major": 5,
      "minor": 0,
      "patch": 0
    }
