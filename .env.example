# Database Configuration
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/remyafya
POSTGRES_DB=remyafya
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-here
SECRET_KEY=your-flask-secret-key-here

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Flask Configuration
FLASK_APP=wsgi:app
FLASK_ENV=development
FLASK_DEBUG=True

# Application Configuration
PYTHONPATH=/app/backend

# CORS — comma-separated list of allowed origins.
# Production example (Render + Vercel): CORS_ORIGINS=https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:3000
